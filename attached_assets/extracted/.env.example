# انسخ هذا الملف إلى .env محلياً — وعلى Replit أضِف نفس المفاتيح في Secrets
# لا ترفع ملف .env إلى GitHub أبداً (موجود في .gitignore)

# --- إجباري ---
# أنشئ مفتاحاً قوياً: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ANTHROPIC_API_KEY=

# --- البيئة ---
ENVIRONMENT=development          # production عند النشر
DEBUG=false

# --- الكوكيز ---
COOKIE_SECURE=false              # true إجبارياً في الإنتاج (HTTPS)
COOKIE_SAMESITE=strict

# --- CORS: نطاقات الواجهة مفصولة بفاصلة ---
CORS_ORIGINS=http://localhost:5173

# --- قاعدة البيانات ---
DATABASE_URL=sqlite:///./app.db

# --- نماذج Claude (اختياري — لها قيم افتراضية) ---
# MODEL_FAST=claude-haiku-4-5-20251001
# MODEL_VISION=claude-sonnet-4-6
# MODEL_PRICES=claude-sonnet-4-6

# --- الحصص (اختياري) ---
# DEVICE_DAILY_QUOTA=5
# USER_DAILY_QUOTA=25
# IP_BURST_PER_MINUTE=8
# IP_DAILY_BACKSTOP=25
